SQLITE_DB_PATH=./local.sqlite
CORS_ORIGINS=http://localhost:5173
COOKIE_SECURE=
COOKIE_SAMESITE=lax
GCS_BUCKET_NAME=
GCS_DB_OBJECT=devforge/dev/db.sqlite
ADMIN_TOKEN=

# ---- 認証・暗号化設定 ----
# JWTの署名キー（生成方法: python -c "import secrets; print(secrets.token_hex(32))"）
SECRET_KEY=

# DBフィールド暗号化キー（生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"）
FIELD_ENCRYPTION_KEY=

# ---- GitHub OAuth ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- LLM 設定 ----
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:31b
OLLAMA_TIMEOUT=1200
VERTEX_PROJECT_ID=
VERTEX_LOCATION=asia-northeast1
VERTEX_MODEL=gemini-2.5-flash-lite

# ---- バックグラウンドタスク設定 ----
TASK_RUNNER=local
# Cloud Tasks 用（TASK_RUNNER=cloud_tasks の場合のみ必要）
# GCP_PROJECT_ID=
# CLOUD_TASKS_QUEUE=devforge-ai-tasks
# CLOUD_TASKS_LOCATION=asia-northeast1
# CLOUD_TASKS_SERVICE_URL=https://<cloud-run-service-url>
# CLOUD_TASKS_SERVICE_ACCOUNT=<sa-email>

# ---- Upstash Redis（GitHub分析進捗機能）----                                                                                                                                              
UPSTASH_REDIS_URL=                                                                                                                                                                   
UPSTASH_REDIS_TOKEN=